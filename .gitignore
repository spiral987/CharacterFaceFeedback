# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# monorepo / workspace
**/node_modules/
**/.next/

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# python / backend
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
.Python
*.egg-info/
.eggs/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# backend local envs and build outputs
/backend/.venv/
/backend/venv/
/backend/dist/
/backend/build/
